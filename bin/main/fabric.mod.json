{
  "schemaVersion": 1,
  "id": "aiinventorysort",
  "version": "${version}",
  "name": "AI Inventory Sort",
  "description": "Sorts your inventory using AI. Takes snapshots of your preferred layout and replicates it.",
  "authors": ["You"],
  "contact": {},
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.aiinventorysort.AiInventorySort"],
    "client": ["com.aiinventorysort.client.AiInventorySortClient"]
  },
  "mixins": [
    "aiinventorysort.mixins.json",
    {
      "config": "aiinventorysort.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.5",
    "fabric-api": "*",
    "minecraft": "~1.21.1",
    "java": ">=21"
  }
}
